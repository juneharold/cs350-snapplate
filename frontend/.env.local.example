# Frontend dev config. Copy to .env.local to override defaults.

# Backend the dev proxy forwards /v1/* to (see next.config.mjs rewrites).
# Default: http://localhost:8000
API_URL=http://localhost:8000

# Use the real backend instead of MSW mocks. Set to "false" to hit the backend.
# (Mocks are ON by default so the frontend runs standalone.)
NEXT_PUBLIC_ENABLE_MOCKS=false
